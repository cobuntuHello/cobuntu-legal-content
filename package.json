{
  "name": "@cobuntu/legal-content",
  "version": "0.1.0",
  "description": "Single canonical source for Cobuntu's Terms of Service and Privacy Policy content components, consumed by the community app and the admin app so the two can never diverge.",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./*": "./src/*"
  },
  "files": [
    "src"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.6.0"
  }
}
